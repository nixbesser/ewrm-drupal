{
  "name": "ewrm-world",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.25",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "vite": "^7.3.1"
  }
}

{
  "scripts": {
    "build:world": "VITE_API_BASE=https://api.ewrm.io vite build",
    "deploy:world:prod": "rsync -avz --delete dist/ deploy@ewrm.com:/var/www/ewrm-com/world/",
    "deploy:world:cms": "rsync -avz --delete dist/ deploy@cms.ewrm.io:/var/www/cms/web/world/",
    "verify:world:prod": "ssh deploy@ewrm.com \"grep -R -o 'FORCE 1\\|Song tile' /var/www/ewrm-com/world | sort | uniq -c\""
  }
}
